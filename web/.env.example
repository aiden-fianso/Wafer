# Wafer web — Hedera testnet (chain 296)
# Copy to `.env` and fill after the WaferVault contract is deployed.
# Everything here is PUBLIC config (no private keys in the frontend).

# WaferVault contract EVM address (0x...). Leave as the zero address to run in
# mock mode (the UI renders with placeholder data, no live reads/writes).
VITE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Pool-share token EVM address for pool 0 (0x...). Optional convenience override;
# normally read from the contract's pools(poolId).shareToken view once deployed.
VITE_SHARE_TOKEN=0x0000000000000000000000000000000000000000

# Optional RPC / mirror overrides (defaults below are Hedera testnet public infra).
VITE_RPC_URL=https://testnet.hashio.io/api
VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
