# Wafer web — Hedera testnet (chain 296)
# OPTIONAL overrides. The live vault + pool-0 share-token addresses are baked into
# src/lib/config.js, so the app talks to the live deploy with NO .env at all.
# Copy to `.env` only to point at a different deploy or force mock mode.
# Everything here is PUBLIC config (no private keys in the frontend).

# WaferVault contract EVM address (0x...). Defaults to the live testnet deploy
# (0xc452D23791F9fC0c43B82E298b337B0A3525cd0A). Set the zero address below to run
# in mock mode (the UI renders with placeholder data, no live reads/writes).
# VITE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Pool-share token EVM address for pool 0 (0x...). Defaults to the live one
# (0x00000000000000000000000000000000008CC571 = 0.0.9225585). Normally read from
# the contract's pools(poolId).shareToken view at runtime.
# VITE_SHARE_TOKEN=0x00000000000000000000000000000000008CC571

# Optional RPC / mirror overrides (defaults below are Hedera testnet public infra).
# VITE_RPC_URL=https://testnet.hashio.io/api
# VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
